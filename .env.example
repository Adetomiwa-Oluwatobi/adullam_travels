# ─────────────────────────────────────────────────────────────
# ADULLAM TRAVELS — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values in .env
# 3. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────


# ── SECURITY ─────────────────────────────────────────────────

# Required. Generate one at: https://djecrety.ir
SECRET_KEY=your-very-long-random-secret-key-here

# Set to True only during local development
DEBUG=True

# Comma-separated. Add your domain in production e.g. adullamtravels.com,www.adullamtravels.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Production HTTPS settings (only applied when DEBUG=False)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000


# ── DATABASE ─────────────────────────────────────────────────

# Local development — SQLite (leave these as-is, no setup needed)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Production — PostgreSQL (uncomment and fill in)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=adullam_db
# DB_USER=adullam_user
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432


# ── LOCALISATION ─────────────────────────────────────────────

LANGUAGE_CODE=en-us
TIME_ZONE=Africa/Lagos


# ── STATIC & MEDIA FILES ─────────────────────────────────────

STATIC_URL=/static/
STATIC_ROOT_DIR=staticfiles

MEDIA_URL=/media/
MEDIA_ROOT_DIR=media


# ── EMAIL ────────────────────────────────────────────────────
# Dev: prints emails to console (no setup needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: use SMTP e.g. Gmail, Zoho, Mailgun
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=hello@adullamtravels.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Adullam Travels <hello@adullamtravels.com>


# ── INSTAGRAM ────────────────────────────────────────────────

INSTAGRAM_HANDLE=adullamtravels
INSTAGRAM_URL=https://www.instagram.com/adullamtravels?igsh=YzljYTk1ODg3Zg==
